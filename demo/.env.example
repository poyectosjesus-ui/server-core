# Configuración de conexión SSH para el Servidor Demo (BoxOps)
# Copia este archivo como .env y coloca tus credenciales reales.

# Dirección del servidor demo (IP o Dominio)
DEMO_SERVER_HOST="192.168.1.100"

# Puerto SSH (por defecto es 22)
DEMO_SERVER_PORT="22"

# Usuario con permisos de sudo o root
DEMO_SERVER_USER="root"

# Autenticación:
# Opción A: Ruta a la llave SSH (Recomendado)
DEMO_SSH_KEY_PATH="~/.ssh/id_rsa"

# Opción B: Contraseña (Menos seguro)
DEMO_SERVER_PASSWORD="tu_password_segura"
